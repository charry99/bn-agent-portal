{
  "version": 2,
  "functions": {
    "app.py": {
      "runtime": "python3.12"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/checkin",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/post-listings",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/send-messages",
      "schedule": "0 18 * * *"
    }
  ]
}